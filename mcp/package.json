{
  "name": "gemini-code-assist-admin-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for Gemini Code Assist administration — license management, metrics, and repository indexing.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gemini",
    "google-cloud",
    "gemini-code-assist",
    "gca",
    "admin",
    "ai",
    "claude",
    "cursor"
  ],
  "license": "Apache-2.0",
  "author": "Paul Datta",
  "homepage": "https://pauldatta.github.io/gemini-code-assist-admin-mcp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldatta/gemini-code-assist-admin-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/pauldatta/gemini-code-assist-admin-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "gemini-code-assist-admin-mcp": "dist/index.js",
    "gca-admin": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
